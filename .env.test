# Capy-POS Test Environment
# Used for automated testing (unit, integration, E2E)

# Application
NODE_ENV=test
PORT=4200

# API Configuration
API_BASE_URL=http://localhost:4200/api
API_TIMEOUT=10000

# Database Configuration (in-memory for tests)
DATABASE_URL=memory://test
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5

# Authentication (test keys)
AUTH_SECRET=test_secret_key_not_for_production
JWT_SECRET=test_jwt_secret_not_for_production
JWT_EXPIRATION=1h

# Payment Gateway (mock/test mode)
STRIPE_PUBLIC_KEY=pk_test_mock
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_test_mock

# Analytics & Monitoring (disabled)
SENTRY_DSN=
SENTRY_ENVIRONMENT=test
SENTRY_TRACES_SAMPLE_RATE=0

# Logging
LOG_LEVEL=error
LOG_FORMAT=simple

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_ANALYTICS=false
ENABLE_TELEMETRY=false
ENABLE_AUDIT_LOGGING=false

# Cache Configuration
CACHE_TTL=60
CACHE_MAX_SIZE=10

# Rate Limiting (disabled for tests)
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=10000

# Circuit Breaker Configuration (fast timeouts for tests)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=1
CIRCUIT_BREAKER_TIMEOUT=1000
CIRCUIT_BREAKER_MONITORING_PERIOD=5000

# Retry Configuration (minimal for tests)
RETRY_MAX_ATTEMPTS=2
RETRY_INITIAL_DELAY=100
RETRY_MAX_DELAY=1000
RETRY_BACKOFF_MULTIPLIER=2

# Email Configuration (disabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=test@capy-pos.test

# SMS Configuration (disabled)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Storage Configuration (mock)
STORAGE_BUCKET=test-bucket
STORAGE_REGION=local

# Backup Configuration (disabled)
BACKUP_ENABLED=false
BACKUP_INTERVAL=86400000
BACKUP_RETENTION_DAYS=1