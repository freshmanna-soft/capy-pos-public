{
  "name": "capy-pos",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "NODE_OPTIONS='--disable-warning=DEP0205' vitest run",
    "test:unit": "NODE_OPTIONS='--disable-warning=DEP0205' vitest run",
    "test:unit:watch": "NODE_OPTIONS='--disable-warning=DEP0205' vitest",
    "test:e2e": "playwright test",
    "test:e2e:gate": "playwright test tests/e2e/persona-workflows.spec.ts --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:cucumber": "cucumber-js",
    "test:cucumber:ci": "start-server-and-test start http://localhost:4200 test:cucumber",
    "test:all": "npm run test:unit && npm run test:e2e",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:sonar": "eslint --no-error-on-unmatched-pattern --config eslint.sonar.config.js --max-warnings 0",
    "sonar:local": "source .env && sonar-scanner",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "storybook": "ng run capy-pos:storybook",
    "build-storybook": "ng run capy-pos:build-storybook",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/animations": "^21.2.14",
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.12",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@types/sql.js": "^1.4.11",
    "better-sqlite3": "^12.10.0",
    "dexie": "^4.4.2",
    "jose": "^6.2.3",
    "rxjs": "~7.8.0",
    "sql.js": "^1.14.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.0",
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-devkit/core": "^21.2.0",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@compodoc/compodoc": "^1.1.0",
    "@cucumber/cucumber": "^13.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/angular": "^10.4.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "angular-eslint": "21.4.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "start-server-and-test": "^3.0.11",
    "storybook": "^10.4.1",
    "stylelint": "^17.13.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.html": [
      "prettier --write"
    ],
    "src/**/*.scss": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "esbuild@0.27.3": true
  }
}
