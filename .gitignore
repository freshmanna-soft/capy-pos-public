# =============================================================================
/coverage
/test-results
/playwright-report
/playwright/.cache
testem.log

# =============================================================================
# Angular
# =============================================================================
/.angular/cache

# =============================================================================
# Storybook
# =============================================================================
*storybook.log
storybook-static

# =============================================================================
